  64          void Relay_self_checking_relays() {
  65   1        uint8_t i = 0;
  66   1        // 流水检测所有继电器
  67   1        for (i = 1; i <= 4; i++) {
  68   2          Relay_set_state(i, 1); // Turn on relay
