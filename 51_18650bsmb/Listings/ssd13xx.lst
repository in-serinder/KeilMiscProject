 362           **************************************************************************************************/
 363          void SSD13XX_WriteCommand(unsigned char command) {
C51 COMPILER V9.59.0.0   SSD13XX                                                           07/03/2026 13:41:52 PAGE 7   

 364   1        I2C_Start();
 365   1        I2C_SendByte(SSD13XX_I2C_ADDRESS << 1); // 发送器件地址+W
 366   1        I2C_WaitAck();
 367   1        I2C_SendByte(SSD13XX_CONTROL_BYTE_CMD_SINGLE); // 控制字节，表示后面是命令
 368   1        I2C_WaitAck();
 369   1        I2C_SendByte(command); // 发送命令
 370   1        I2C_WaitAck();
 371   1        I2C_Stop();
 372   1      }
