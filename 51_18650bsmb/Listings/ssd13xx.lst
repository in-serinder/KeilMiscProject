 720           **************************************************************************************************/
 721          void SSD13XX_WriteString(unsigned char x, unsigned char y, char *str,
 722                                   FontSize size) {
 723   1        unsigned char cx = x, cy = y;
 724   1        unsigned char char_width = (size == FONT_8X8) ? 8 : 16;
 725   1        unsigned char char_height = (size == FONT_8X8) ? 8 : 16;
 726   1      
 727   1        if (y % 8 != 0)
 728   1          return; // 简化：要求起始坐标页对齐
 729   1      
 730   1        while (*str) {
 731   2          if (cx + char_width > SSD13XX_WIDTH) {
 732   3            cx = 0;
 733   3            cy += char_height;
 734   3            if (cy + char_height > SSD13XX_HEIGHT)
 735   3              break;
C51 COMPILER V9.59.0.0   SSD13XX                                                           07/03/2026 13:41:52 PAGE 13  

 736   3          }
 737   2          SSD13XX_WriteChar(cx, cy, *str, size);
 738   2          cx += char_width;
 739   2          str++;
 740   2        }
 741   1      }
