 674   2          col = x;
 675   2          // font = SSD13xx_Font16x16[c - ' '];
 676   2          font = SSD13xx_Font8x8[c - ' '];
 677   2          // 失能16x16字体，使用8x8字体显示 优化空间
 678   2          //  发送上半部分（第 0 ~ 7 行）
 679   2          SSD13XX_WriteCommand(0xB0 | page);
 680   2          SSD13XX_WriteCommand(col & 0x0F);
 681   2          SSD13XX_WriteCommand(0x10 | (col >> 4));
 682   2          for (i = 0; i < 8; i++) {
 683   3            SSD13XX_WriteData(font[i]);
 684   3          }
 685   2          // 发送下半部分（第 8 ~ 15 行）
 686   2          SSD13XX_WriteCommand(0xB0 | (page + 1));
 687   2          SSD13XX_WriteCommand(col & 0x0F);
 688   2          SSD13XX_WriteCommand(0x10 | (col >> 4));
 689   2          for (i = 8; i < 16; i++) {
 690   3            SSD13XX_WriteData(font[i]);
 691   3          }
 692   2        }
 693   1      }
