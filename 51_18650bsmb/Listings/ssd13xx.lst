 641          /***************************************************************************************************
 642           * 函数名: SSD13XX_WriteChar
 643           * 描述: 在指定位置显示单个字符
 644           * 输入: x, y - 字符显示起始坐标
 645           *       c - 要显示的字符
 646           *       size - 字符大小(FONT_8X8或FONT_16X16)
 647           * 输出: 无
 648           * 返回: 无
 649           * 注意: 支持8x8和16x16两种字体大小，自动处理跨页显示
 650           **************************************************************************************************/
 651          void SSD13XX_WriteChar(unsigned char x, unsigned char y, char c,
 652                                 FontSize size) {
 653   1        unsigned char page, col, i;
 654   1        const unsigned char *font;
 655   1        if (c < ' ' || c > '~')
 656   1          c = ' ';
 657   1      
 658   1        if (size == FONT_8X8) {
 659   2          if (y % 8 != 0)
 660   2            return; // 必须页对齐
 661   2          page = y / 8;
 662   2          col = x;
 663   2          font = SSD13xx_Font8x8[c - ' '];
 664   2          SSD13XX_WriteCommand(0xB0 | page);
 665   2          SSD13XX_WriteCommand(col & 0x0F);
 666   2          SSD13XX_WriteCommand(0x10 | (col >> 4));
 667   2          for (i = 0; i < 8; i++) {
 668   3            SSD13XX_WriteData(font[i]);
 669   3          }
 670   2        } else if (size == FONT_16X16) {
 671   2          if (y % 8 != 0)
 672   2            return; // 16x16 也要求页对齐，避免跨更多页
 673   2          page = y / 8;
