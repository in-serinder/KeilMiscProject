 385   1        I2C_WaitAck();
 386   1        I2C_SendByte(SSD13XX_CONTROL_BYTE_DATA_STREAM); // 控制字节，表示后面是数据
 387   1        I2C_WaitAck();
 388   1        I2C_SendByte(dat); // 发送数据
 389   1        I2C_WaitAck();
 390   1        I2C_Stop();
 391   1      }
