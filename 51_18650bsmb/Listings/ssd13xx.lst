 450           * 返回: 无
 451           * 注意: 这是一个内部辅助函数，直接操作缓冲区
 452           **************************************************************************************************/
 453          static void _DrawPixelOnPage(unsigned char x, unsigned char y_in_page,
 454                                       unsigned char color) {
 455   1        unsigned char mask;
 456   1        if (x >= SSD13XX_WIDTH || y_in_page >= 8)
 457   1          return;
