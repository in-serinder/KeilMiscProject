 789          /**
 790           * @brief 绘制一个进度条组件（占用一个Page，高度8像素）
 791           * @param x        组件左上角X坐标（通常为0）
 792           * @param y        组件左上角Y坐标（必须是8的倍数）
 793           * @param width    组件总宽度（像素）
 794           * @param left_str 左侧显示的字符串（如 "CPU"）
 795           * @param right_str 右侧显示的字符串（如 "67%"），可为NULL
 796           * @param percent  进度百分比（0~100）
 797           */
C51 COMPILER V9.59.0.0   SSD13XX                                                           07/03/2026 13:41:52 PAGE 14  

 798          void Draw_ProgressBar_Component(unsigned char x, unsigned char y,
 799                                          unsigned char width, char *left_str,
 800                                          char *right_str, unsigned char percent) {
 801   1        unsigned char left_width, right_width, remaining_width, fill_width;
 802   1        unsigned char bar_start_x, bar_end_x;
 803   1        unsigned char i;
 804   1      
 805   1        // 参数检查：y必须为8的倍数，否则文本无法显示
 806   1        if (y % 8 != 0)
 807   1          return;
 808   1        if (percent > 100)
 809   1          percent = 100;
 810   1        if (width < 20)
 811   1          return; // 太窄无法绘制
 812   1      
 813   1        // 计算左右文本占据的像素宽度（每个字符8像素）
 814   1        left_width = (left_str != NULL) ? (strlen(left_str) * 8) : 0;
 815   1        right_width = (right_str != NULL) ? (strlen(right_str) * 8) : 0;
 816   1      
 817   1        // 剩余宽度用于进度条（左右各留1像素边距）
 818   1        remaining_width = width - left_width - right_width - 2; // 减2是两侧留白
 819   1        if (remaining_width < 10)
 820   1          remaining_width = 10; // 最小宽度
 821   1      
 822   1        // 进度条填充宽度
 823   1        fill_width = (remaining_width * percent) / 100;
 824   1        if (fill_width < 0)
 825   1          fill_width = 0;
 826   1        if (fill_width > remaining_width)
 827   1          fill_width = remaining_width;
 828   1      
 829   1        // 计算进度条的起始和结束坐标
 830   1        bar_start_x = x + left_width + 1;        // 左侧文本后空1像素
 831   1        bar_end_x = x + width - right_width - 1; // 右侧文本前空1像素
 832   1      
 833   1        // 绘制进度条外框（高度4px，从 y+2 到 y+5）
 834   1        SSD13XX_DrawRectangle(bar_start_x, y + 2, bar_end_x, y + 5, 1);
 835   1      
 836   1        // 绘制填充部分（内部用横线填充，填充区域为 bar_start_x+1 到
 837   1        // bar_start_x+fill_width，行范围为 y+2+1 到 y+5-1）
 838   1        if (fill_width > 0) {
 839   2          for (i = y + 3; i <= y + 4;
 840   2               i++) { // 绘制两行横线，使4px高度有较好的填充效果
 841   3            SSD13XX_DrawLine(bar_start_x + 1, i, bar_start_x + fill_width, i, 1);
 842   3          }
 843   2        }
 844   1      
 845   1        if (left_str != NULL) {
 846   2          SSD13XX_WriteString(x, y, left_str, FONT_8X8);
 847   2        }
 848   1      
 849   1        if (right_str != NULL) {
 850   2          unsigned char right_text_x = x + width - right_width;
 851   2          SSD13XX_WriteString(right_text_x, y, right_str, FONT_8X8);
 852   2        }
 853   1      }
