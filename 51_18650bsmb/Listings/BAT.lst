  66          float BAT_ADC_ReadVoltage(BAT_Channel ch) {
  67   1        uint16_t adc_value = BAT_ADC_Read(ch);
  68   1        // 电压 = (ADC值 / 分辨率) * 参考电压
  69   1        return (adc_value / ADC_RESOLUTION) * REF_VOLTAGE;
  70   1      }
