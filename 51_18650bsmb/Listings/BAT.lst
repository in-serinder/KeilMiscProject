  72          // 电量估算
  73          float VoltageToSOC(float ocv) {
  74   1        uint8_t i, s1, s2;
  75   1        float v1, v2, ratio, soc;
  76   1        // SOC数组
  77   1        float v_table[] = {4.20f, 4.06f, 3.98f, 3.92f, 3.87f, 3.82f,
  78   1                           3.79f, 3.77f, 3.74f, 3.68f, 3.45f, 3.00f};
  79   1        uint8_t soc_table[] = {100, 90, 80, 70, 60, 50, 40, 30, 20, 10, 5, 0};
  80   1        uint8_t len = sizeof(v_table) / sizeof(float);
  81   1      
  82   1        // 满电/亏电边界
  83   1        if (ocv >= 4.20f)
  84   1          return 100;
  85   1        if (ocv <= 3.00f)
  86   1          return 0;
  87   1      
  88   1        // 查找区间
  89   1        for (i = 0; i < len - 1; i++) {
  90   2          v1 = v_table[i];
  91   2          v2 = v_table[i + 1];
  92   2          s1 = soc_table[i];
  93   2          s2 = soc_table[i + 1];
  94   2      
  95   2          if (ocv <= v1 && ocv >= v2) {
  96   3            // 线性插值
  97   3            ratio = (v1 - ocv) / (v1 - v2);
  98   3            soc = s1 - ratio * (s1 - s2);
  99   3            return (uint8_t)(soc + 0.5f);
 100   3          }
 101   2        }
 102   1        return 0;
 103   1      }


