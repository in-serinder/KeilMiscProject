  11          /**
  12           * @brief ADC初始化函数
  13           * @note 配置P10-P13为模拟输入，使能ADC模块
  14           */
  15          void BAT_ADC_Init(void) {
  16   1        // 设置P10-P13为高阻输入模式（模拟输入）
  17   1        P1M0 &= ~(0x0F); // P10-P13设置为高阻输入
  18   1        P1M1 |= 0x0F;
  19   1      
  20   1        // 设置ADC时钟分频，ADC时钟 = Fosc / (ADC_CLK + 1)
  21   1        // 建议ADC时钟在500kHz ~ 1.5MHz之间
  22   1        CLK_DIV &= ~(0x07); // 清除ADC时钟分频位
  23   1        CLK_DIV |= 0x03;    // ADC_CLK = 3, ADC时钟 = Fosc/4
  24   1      
  25   1        // 使能ADC电源
  26   1        ADC_CONTR |= 0x80; // ADC_POWER = 1
  27   1      
  28   1        // 延时等待ADC稳定
  29   1        // 实际应用中可添加适当延时
  30   1      }
