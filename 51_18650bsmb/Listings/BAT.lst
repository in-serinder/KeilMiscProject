  32          /**
  33           * @brief 读取指定通道的ADC原始值
  34           * @param ch: ADC通道 (BAT_CH1 ~ BAT_CH4)
  35           * @return 10位ADC值 (0 ~ 1023)
  36           */
  37          uint16_t BAT_ADC_Read(BAT_Channel ch) {
  38   1        uint16_t adc_value;
  39   1      
  40   1        // 选择ADC通道
  41   1        ADC_CONTR &= ~(0x0F);     // 清除通道选择位
  42   1        ADC_CONTR |= (ch & 0x0F); // 设置通道号
  43   1      
  44   1        // 启动ADC转换
  45   1        ADC_CONTR |= 0x40; // ADC_START = 1
  46   1      
  47   1        // 等待转换完成
  48   1        while (!(ADC_CONTR & 0x20))
  49   1          ; // 等待ADC_FLAG = 1
  50   1      
  51   1        // 读取ADC结果
  52   1        adc_value = (uint16_t)ADC_RES << 2;
  53   1        adc_value |= (ADC_RESL & 0x03);
  54   1      
