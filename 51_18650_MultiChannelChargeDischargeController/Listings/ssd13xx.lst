 488           * 函数名: SSD13XX_DrawLine
 489           * 描述: 绘制一条直线
 490           * 输入: x1, y1 - 起始点坐标
 491           *       x2, y2 - 结束点坐标
 492           *       color - 线条颜色(0=黑色/关闭, 1=白色/点亮)
 493           * 输出: 无
 494           * 返回: 无
 495           * 注意: 使用Bresenham算法绘制直线，自动处理跨页情况
 496           **************************************************************************************************/
 497          void SSD13XX_DrawLine(unsigned char x1, unsigned char y1, unsigned char x2,
 498                                unsigned char y2, unsigned char color) {
 499   1        int idata dx, dy, stepX, stepY, err, x, y;
 500   1        unsigned char idata currentPage, row, page, i;
 501   1        dx = (x2 > x1) ? (x2 - x1) : (x1 - x2);
 502   1        dy = (y2 > y1) ? (y2 - y1) : (y1 - y2);
 503   1        stepX = (x2 >= x1) ? 1 : -1;
 504   1        stepY = (y2 >= y1) ? 1 : -1;
 505   1        err = dx - dy;
 506   1        x = x1;
 507   1        y = y1;
 508   1        currentPage = y / 8;
 509   1        for (i = 0; i < SSD13XX_PAGE_WIDTH; i++)
 510   1          SSD13XX_PageBuffer[i] = 0x00;
 511   1      
 512   1        while (1) {
 513   2          page = y / 8;
 514   2          row = y % 8;
 515   2          if (page != currentPage) {
 516   3            SSD13XX_FlushPage(currentPage);
 517   3            for (i = 0; i < SSD13XX_PAGE_WIDTH; i++)
 518   3              SSD13XX_PageBuffer[i] = 0x00;
 519   3            currentPage = page;
 520   3          }
 521   2          _DrawPixelOnPage(x, row, color);
 522   2          if (x == x2 && y == y2)
 523   2            break;
 524   2          if (err * 2 > -dy) {
 525   3            err -= dy;
 526   3            x += stepX;
 527   3          }
 528   2          if (err * 2 < dx) {
 529   3            err += dx;
 530   3            y += stepY;
 531   3          }
 532   2        }
 533   1        SSD13XX_FlushPage(currentPage);
 534   1      }
