 642          /***************************************************************************************************
 643           * 函数名: SSD13XX_WriteChar
 644           * 描述: 在指定位置显示单个字符
 645           * 输入: x, y - 字符显示起始坐标
 646           *       c - 要显示的字符
 647           *       size - 字符大小(FONT_8X8或FONT_16X16)
 648           * 输出: 无
 649           * 返回: 无
 650           * 注意: 支持8x8和16x16两种字体大小，自动处理跨页显示
 651           **************************************************************************************************/
 652          void SSD13XX_WriteChar(unsigned char x, unsigned char y, char c,
 653                                 FontSize size) {
 654   1        unsigned char page, col, i;
 655   1        const unsigned char *font;
 656   1        if (c < ' ' || c > '~')
 657   1          c = ' ';
 658   1      
 659   1        if (size == FONT_8X8) {
 660   2          if (y % 8 != 0)
 661   2            return; // 必须页对齐
 662   2          page = y / 8;
 663   2          col = x;
 664   2          font = SSD13xx_Font8x8[c - ' '];
 665   2          SSD13XX_WriteCommand(0xB0 | page);
 666   2          SSD13XX_WriteCommand(col & 0x0F);
 667   2          SSD13XX_WriteCommand(0x10 | (col >> 4));
 668   2          for (i = 0; i < 8; i++) {
 669   3            SSD13XX_WriteData(font[i]);
 670   3          }
 671   2        } else if (size == FONT_16X16) {
 672   2          if (y % 8 != 0)
 673   2            return; // 16x16 也要求页对齐，避免跨更多页
C51 COMPILER V9.59.0.0   SSD13XX                                                           07/19/2026 19:31:00 PAGE 12  

 674   2          page = y / 8;
 675   2          col = x;
 676   2          // font = SSD13xx_Font16x16[c - ' '];
 677   2          font = SSD13xx_Font8x8[c - ' '];
 678   2          // 失能16x16字体，使用8x8字体显示 优化空间
 679   2          //  发送上半部分（第 0 ~ 7 行）
 680   2          SSD13XX_WriteCommand(0xB0 | page);
 681   2          SSD13XX_WriteCommand(col & 0x0F);
 682   2          SSD13XX_WriteCommand(0x10 | (col >> 4));
 683   2          for (i = 0; i < 8; i++) {
 684   3            SSD13XX_WriteData(font[i]);
 685   3          }
 686   2          // 发送下半部分（第 8 ~ 15 行）
 687   2          SSD13XX_WriteCommand(0xB0 | (page + 1));
 688   2          SSD13XX_WriteCommand(col & 0x0F);
 689   2          SSD13XX_WriteCommand(0x10 | (col >> 4));
 690   2          for (i = 8; i < 16; i++) {
 691   3            SSD13XX_WriteData(font[i]);
 692   3          }
 693   2        }
 694   1      }
