 712          /***************************************************************************************************
 713           * 函数名: SSD13XX_WriteString
 714           * 描述: 在指定位置显示字符串
 715           * 输入: x, y - 字符串显示起始坐标
 716           *       str - 要显示的字符串指针
 717           *       size - 字符大小(FONT_8X8或FONT_16X16)
 718           * 输出: 无
 719           * 返回: 无
 720           * 注意: 自动处理换行，支持8x8和16x16字体
 721           **************************************************************************************************/
 722          void SSD13XX_WriteString(unsigned char x, unsigned char y, char *str,
 723                                   FontSize size) {
 724   1        unsigned char cx = x, cy = y;
 725   1        unsigned char char_width = (size == FONT_8X8) ? 8 : 16;
 726   1        unsigned char char_height = (size == FONT_8X8) ? 8 : 16;
 727   1      
 728   1        if (y % 8 != 0)
 729   1          return; // 简化：要求起始坐标页对齐
 730   1      
 731   1        while (*str) {
 732   2          if (cx + char_width > SSD13XX_WIDTH) {
 733   3            cx = 0;
 734   3            cy += char_height;
 735   3            if (cy + char_height > SSD13XX_HEIGHT)
C51 COMPILER V9.59.0.0   SSD13XX                                                           07/19/2026 19:31:00 PAGE 13  

 736   3              break;
 737   3          }
 738   2          SSD13XX_WriteChar(cx, cy, *str, size);
 739   2          cx += char_width;
 740   2          str++;
 741   2        }
 742   1      }
