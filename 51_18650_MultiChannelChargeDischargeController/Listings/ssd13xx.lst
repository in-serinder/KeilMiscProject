 879           * @param percent   第二行右侧显示的百分比数值（0-100）
 880           *
 881           * ★ 重写v2：全部用WriteString和直接写数据实现
 882           */
 883          void Draw_ProgressBar_Double(unsigned char x, unsigned char y,
 884                                       unsigned char width, char *title,
 885                                       char *title_right, char *label,
 886                                       unsigned char percent) {
 887   1        unsigned char col;
 888   1        unsigned char bar_start, bar_end, fill_len;
 889   1        unsigned char p_page, second_y;
 890   1        unsigned char label_len;
 891   1      
 892   1        // 必须页对齐
 893   1        if (y % 8 != 0)
 894   1          return;
 895   1        if (percent > 100)
 896   1          percent = 100;
 897   1        if (width < 30)
 898   1          return;
 899   1      
 900   1        second_y = y + 8;
 901   1      
 902   1        // ====== ★ 自动页刷新：先清除占用的2个页 ======
 903   1        SSD13XX_ClearPage(y / 8);
 904   1        SSD13XX_ClearPage(second_y / 8);
 905   1      
 906   1        // ====== 第一行文本 ======
 907   1        if (title != NULL)
 908   1          SSD13XX_WriteString(x, y, title, FONT_8X8);
 909   1        if (title_right != NULL) {
 910   2          unsigned char tr_len = 0;
 911   2          char *p = title_right;
 912   2          while (*p) {
 913   3            tr_len++;
 914   3            p++;
 915   3          }
 916   2          SSD13XX_WriteString(x + width - tr_len * 8, y, title_right, FONT_8X8);
 917   2        }
 918   1      
 919   1        // ====== 第二行左侧标签 ======
 920   1        if (label != NULL)
 921   1          SSD13XX_WriteString(x, second_y, label, FONT_8X8);
C51 COMPILER V9.59.0.0   SSD13XX                                                           07/19/2026 19:31:00 PAGE 16  

 922   1      
 923   1        // ====== 百分比字符串（右对齐，统一3位格式：百十个%或 空格十%） ======
 924   1        if (percent >= 100) {
 925   2          SSD13XX_WriteChar(x + width - 32, second_y, '0' + (percent / 100) % 10,
 926   2                            FONT_8X8);
 927   2          SSD13XX_WriteChar(x + width - 24, second_y, '0' + (percent / 10) % 10,
 928   2                            FONT_8X8);
 929   2          SSD13XX_WriteChar(x + width - 16, second_y, '0' + (percent % 10), FONT_8X8);
 930   2          SSD13XX_WriteChar(x + width - 8, second_y, '%', FONT_8X8);
 931   2          bar_end = x + width - 32;
 932   2        } else if (percent >= 10) {
 933   2          SSD13XX_WriteChar(x + width - 32, second_y, ' ', FONT_8X8);
 934   2          SSD13XX_WriteChar(x + width - 24, second_y, '0' + (percent / 10), FONT_8X8);
 935   2          SSD13XX_WriteChar(x + width - 16, second_y, '0' + (percent % 10), FONT_8X8);
 936   2          SSD13XX_WriteChar(x + width - 8, second_y, '%', FONT_8X8);
 937   2          bar_end = x + width - 32;
 938   2        } else {
 939   2          SSD13XX_WriteChar(x + width - 32, second_y, ' ', FONT_8X8);
 940   2          SSD13XX_WriteChar(x + width - 24, second_y, ' ', FONT_8X8);
 941   2          SSD13XX_WriteChar(x + width - 16, second_y, '0' + percent, FONT_8X8);
 942   2          SSD13XX_WriteChar(x + width - 8, second_y, '%', FONT_8X8);
 943   2          bar_end = x + width - 32;
 944   2        }
 945   1      
 946   1        // ====== 进度条：直接写像素数据 ======
 947   1        bar_start = x + 3;
 948   1        if (bar_end <= bar_start + 4)
 949   1          return;
 950   1      
 951   1        fill_len = ((bar_end - bar_start) * percent) / 100;
 952   1      
 953   1        // 设置OLED页地址到第二行所在的页
 954   1        p_page = second_y / 8;
 955   1        SSD13XX_WriteCommand(0xB0 | p_page);
 956   1        SSD13XX_WriteCommand(bar_start & 0x0F);
 957   1        SSD13XX_WriteCommand(0x10 | (bar_start >> 4));
 958   1      
 959   1        // 逐列写入进度条数据
 960   1        for (col = bar_start; col < bar_end; col++) {
 961   2          unsigned char pixel;
 962   2          if ((col - bar_start) < fill_len) {
 963   3            pixel = 0x3C;
 964   3          } else {
 965   3            pixel = 0x24;
 966   3          }
 967   2          SSD13XX_WriteData(pixel);
 968   2        }
 969   1      }
