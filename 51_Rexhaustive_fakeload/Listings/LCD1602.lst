  94          /**
  95           * @brief  LCD1602初始化函数
  96           * @param  无
  97           * @retval 无
  98           */
  99          void LCD_Init() {
 100   1        // 上电后等待 >15ms 让LCD稳定
 101   1        LCD_LongDelay();
 102   1        LCD_LongDelay();
 103   1        LCD_LongDelay();
 104   1      
 105   1        // 按照HD44780规格书，0x38需要发送3次确保可靠
 106   1        LCD_WriteCommand(0x38); // 八位数据接口，两行显示，5*7点阵
 107   1        LCD_LongDelay();        // 等待 >4.1ms
 108   1        LCD_WriteCommand(0x38);
 109   1        LCD_Delay(); // 等待 >100us
 110   1        LCD_WriteCommand(0x38);
 111   1        LCD_Delay();
 112   1      
 113   1        LCD_WriteCommand(0x0c); // 显示开，光标关，闪烁关
 114   1        LCD_Delay();
 115   1        LCD_WriteCommand(0x01); // 光标复位，清屏（需要最长延时）
 116   1        LCD_LongDelay();        // 清屏需要 >1.64ms，给足5ms
C51 COMPILER V9.59.0.0   LCD1602                                                           07/13/2026 20:10:42 PAGE 3   

 117   1        LCD_WriteCommand(0x06); // 数据读写操作后，光标自动加一，画面不动
 118   1        LCD_Delay();
 119   1      }
