   1          #include "peripheral.h"
   2          #include "Delay.h"
   3          #include "Timer.h"
   4          
   5          uint16_t PWMPeriod = 0;
   6          uint16_t pwmCounter = 0;
   7          uint8_t dutyCycle = 0;
   8          bit buzzer_en = 0;       // 蜂鸣总开关
   9          #define BUZZER_VOLUME 50 // 默认音量50%占空比
  10          #define TICK_PER_SEC 250 // 全局宏，解决未定义报错
  11          
  12          #define Buzzer P36
  13          #define ShellFAN P25
  14          #define EXTFAN P24
  15          #define HEARTFAN P34
  16          #define RUNSTATE_LED P35
  17          
  18          /*功能函数*/
  19          void Timer0_ISR(void) interrupt 1 {
  20   1        TH0 = 0xFC;
  21   1        TL0 = 0x66;
  22   1      
  23   1        if (!buzzer_en) {
  24   2          Buzzer = 0;
  25   2          return;
  26   2        }
  27   1      
  28   1        pwmCounter++;
  29   1        if (pwmCounter >= PWMPeriod) {
  30   2          pwmCounter = 0;
  31   2        }
  32   1      
  33   1        Buzzer = (pwmCounter < dutyCycle) ? 1 : 0;
  34   1      }
  35          
  36          void setBuzzerDutyCycle(uint8_t duty) { dutyCycle = (duty > 100) ? 100 : duty; }
  37          
  38          /*外设函数*/
  39          // freq=0 关闭蜂鸣；freq>0 开启对应频率发声
  40          void BuzzerPWM(uint8_t freq) {
  41   1        if (freq == 0) {
  42   2          buzzer_en = 0;
  43   2          PWMPeriod = 0;
  44   2          Buzzer = 0;
  45   2          return;
  46   2        }
  47   1      
  48   1        buzzer_en = 1;
  49   1        setBuzzerDutyCycle(BUZZER_VOLUME); // 开启默认音量
  50   1      
  51   1        // PWM周期计算
  52   1        PWMPeriod = TICK_PER_SEC / freq;
  53   1      
