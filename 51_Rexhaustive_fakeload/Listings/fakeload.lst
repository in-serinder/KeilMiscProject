 133          // 初始化假负载
 134          void FakeLoad_Init(void) {
 135   1        PCF8574_Init();
 136   1        // 初始化所有电阻继电器关闭
 137   1        PCF8574_SetPort(R10, 0);   // 10R 关闭
 138   1        PCF8574_SetPort(R20_1, 0); // 20R_1 关闭
 139   1        PCF8574_SetPort(R20_2, 0); // 20R_2 关闭
 140   1        PCF8574_SetPort(R20_3, 0); // 20R_3 关闭
 141   1        PCF8574_SetPort(R20_4, 0); // 20R_4 关闭
 142   1        PCF8574_SetPort(R100, 0);  // 100R 关闭
 143   1      }
 144          
 145          // 由指定目标功率计算并设置电阻负载状态 返回索引
 146          uint8_t FakeLoad_SetPower(float power, float voltage) {
 147   1        float xdata target_r;
 148   1        float xdata min_diff = 999.0f;
 149   1        uint8_t xdata best_index = 0;
 150   1        uint8_t xdata i;
 151   1        float xdata diff;
 152   1      
 153   1        if (power == 0) {
 154   2          PCF8574_Write(0xC0);
 155   2          return 0;
 156   2        }
 157   1        target_r = (voltage * voltage) / power;
 158   1      
 159   1        for (i = 0; i < RESISTANCE_LIST_SIZE; i++) {
 160   2          diff = fabs(resistance_list[i] - target_r);
 161   2      
 162   2          if (diff < min_diff) {
 163   3            min_diff = diff;
 164   3            best_index = i;
 165   3          }
 166   2        }
 167   1      
 168   1        PCF8574_Write(resistance_list_hex_list[best_index]);
 169   1      
 170   1        return best_index;
 171   1      }
