 168          // 由指定目标功率计算并设置电阻负载状态 返回索引
 169          uint8_t FakeLoad_SetPower(float power, float voltage) {
 170   1        float xdata target_r;
 171   1        float xdata min_diff = 999.0f;
 172   1        uint8_t xdata best_index = 0;
 173   1        uint8_t xdata i;
 174   1        float xdata diff;
 175   1      
 176   1        if (power == 0) {
 177   2          PCF8574_Write(0xC0);
 178   2          return 0;
C51 COMPILER V9.59.0.0   FAKELOAD                                                          07/13/2026 20:46:45 PAGE 4   

 179   2        }
 180   1        target_r = (voltage * voltage) / power;
 181   1      
 182   1        for (i = 0; i < RESISTANCE_LIST_SIZE; i++) {
 183   2          diff = fabs(resistance_list[i] - target_r);
 184   2      
 185   2          if (diff < min_diff) {
 186   3            min_diff = diff;
 187   3            best_index = i;
 188   3          }
 189   2        }
 190   1      
 191   1        PCF8574_Write(resistance_list_hex_list[best_index]);
 192   1      
 193   1        return best_index;
 194   1      }
 195          
 196          float FakeLoad_getPower(uint8_t resistance_index, float voltage) {
 197   1        // 计算功率 P = V^2 / R
 198   1        if (resistance_list[resistance_index] == 0.0f) {
 199   2          return 0.0f;
 200   2        }
 201   1        return voltage * voltage / resistance_list[resistance_index];
 202   1      }
 203          
 204          void FakeLoad_SetResistance(uint8_t resistance_index) {
 205   1        PCF8574_Write(resistance_list_hex_list[resistance_index]);
 206   1      }
 207          
 208          float FakeLoad_getResistance(uint8_t resistance_index) {
 209   1        return resistance_list[resistance_index];
 210   1      }
 211          void FakeLoad_Reset(void) { PCF8574_Write(0x00); }
