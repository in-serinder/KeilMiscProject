 146          // 由指定目标功率计算并设置电阻负载状态 返回索引
 147          uint8_t FakeLoad_SetPower(float power, float voltage) {
 148   1        float xdata target_r;
 149   1        float xdata min_diff = 999.0f;
 150   1        uint8_t xdata best_index = 0;
 151   1        uint8_t xdata i;
 152   1        float xdata diff;
 153   1      
 154   1        if (power == 0) {
 155   2          PCF8574_Write(0xC0);
 156   2          return 0;
 157   2        }
 158   1        target_r = (voltage * voltage) / power;
 159   1      
 160   1        for (i = 0; i < RESISTANCE_LIST_SIZE; i++) {
 161   2          diff = fabs(resistance_list[i] - target_r);
 162   2      
 163   2          if (diff < min_diff) {
 164   3            min_diff = diff;
 165   3            best_index = i;
 166   3          }
 167   2        }
 168   1      
 169   1        PCF8574_Write(resistance_list_hex_list[best_index]);
 170   1      
 171   1        return best_index;
 172   1      }
