  87   4              voltage_updated = 1;
  88   4              rx_state = 0;
  89   4            } else if (ch == ' ' && rx_idx == 0) {
  90   4              // 跳过 ">>" 后的空格
  91   4            } else {
  92   4              // 提取数字字符（最多7位：XXX.XX）
  93   4              if (rx_idx < 7) {
  94   5                rx_voltage_str[rx_idx++] = ch;
  95   5              }
  96   4            }
  97   3          } else {
