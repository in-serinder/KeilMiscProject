  78   2          if (rx_state == 0 && ch == '>') {
  79   3            rx_state = 1;
  80   3          } else if (rx_state == 1 && ch == '>') {
  81   3            rx_state = 2;
  82   3            rx_idx = 0;
  83   3          } else if (rx_state == 2) {
  84   3            if (ch == '\r' || ch == '\n') {
