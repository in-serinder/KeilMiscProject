  60          // 减少中断占用
  61          void EC11_Init(void) {
  62   1        EC11_A = 1;
  63   1        EC11_B = 1;
  64   1        EC11_KEY = 1;
  65   1      
  66   1        // 只开INT0中断，INT1留给Timer0蜂鸣，禁止INT1中断
  67   1        IT0 = 1; // 下降沿触发（编码器标准）
  68   1        EX0 = 1; // 使能INT0
  69   1        EX1 = 0; // 关闭INT1外部中断，留给定时器0
  70   1      
  71   1        EA = 1; // 全局中断开
  72   1      }
  73          
  74          void disableAint(void) { EX0 = 0; }
  75          void enableAint(void) { EX0 = 1; }
  76          
  77          // 仅A相中断，B相普通IO读取判断方向
  78          void EC11_A_Triggered(void) interrupt 0 {
  79   1        disableAint();
  80   1      
  81   1        if (EC11_B == 0)
  82   1          AB_DIR = 0;
  83   1        else
  84   1          AB_DIR = 1;
  85   1      
  86   1        encode_CallBack(AB_DIR, 0); // 0=旋转
  87   1        enableAint();
  88   1      }
  89          
  90          // 按键不使用中断，主循环轮询调用
  91          bit EC11_ScanKey(void) {
  92   1        if (EC11_KEY == 0) {
  93   2          Delay_ms(20); // 防抖
  94   2          if (EC11_KEY == 0) {
  95   3            while (EC11_KEY == 0)
  96   3              ;                         // 等待松手
  97   3            encode_CallBack(AB_DIR, 1); // 1=按键按下
  98   3            return 1;
  99   3          }
 100   2        }
 101   1        return 0;
 102   1      }
 103          
 104          bit checkDirection(void) { return AB_DIR; }


